COMPOSE_APP_HTTP_PORT=80
COMPOSE_APP_HTTPS_PORT=443
COMPOSE_DB_PORT=3306
COMPOSE_S3_PROXY_PORT=9000
COMPOSE_DNS_PORT=53
COMPOSE_OTEL_GRPC_PORT=4317
COMPOSE_OTEL_HTTP_PORT=4318
COMPOSE_REGISTRY_HTTPS_PORT=443

APP_NAME=Misosiru Cloud
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://mgmt.infra.example.com

APP_LOCALE=ja
APP_FALLBACK_LOCALE=ja
APP_FAKER_LOCALE=ja_JP

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=mgmt-db
DB_PORT=3306
DB_DATABASE=misosiru_cloud
DB_USERNAME=misosiru
DB_PASSWORD=change-me

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-northeast-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

S3_BACKEND_ENDPOINT=https://s3.ap-northeast-1.amazonaws.com
S3_BACKEND_REGION=ap-northeast-1
S3_BACKEND_ACCESS_KEY=
S3_BACKEND_SECRET_KEY=

SAKURA_DNS_BASE_URL=https://secure.sakura.ad.jp/cloud/zone/v1
SAKURA_DNS_API_TOKEN=
SAKURA_DNS_ZONE=

COREDNS_ZONES_PATH=/etc/coredns/zones
COREDNS_COREFILE_PATH=/etc/coredns/Corefile
COREDNS_CONTAINER_NAME=dns

OTEL_EXPORTER_OTLP_ENDPOINT=
HARBOR_HOSTNAME=registry.infra.example.com
HARBOR_ADMIN_PASSWORD=change-me
HARBOR_DB_HOST=mgmt-db
HARBOR_DB_PORT=3306
HARBOR_DB_NAME=registry
HARBOR_DB_USERNAME=misosiru
HARBOR_DB_PASSWORD=change-me
