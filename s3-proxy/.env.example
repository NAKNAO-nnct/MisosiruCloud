# S3 Proxy Configuration

# Backend S3 settings
S3_BACKEND_ENDPOINT=https://s3.amazonaws.com
S3_BACKEND_REGION=us-east-1
S3_BACKEND_ACCESS_KEY=
S3_BACKEND_SECRET_KEY=

# Database settings
DB_HOST=localhost
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=database

# Server settings
LISTEN_ADDR=0.0.0.0
LISTEN_PORT=9000

# Cache settings
CACHE_REFRESH_INTERVAL=5m

# Logging
LOG_LEVEL=info
